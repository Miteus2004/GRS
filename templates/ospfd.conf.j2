! OSPF daemon config — auto-generated by IBN engine
hostname ospfd
password zebra
!
router ospf
  router-id {{ routing.ospf.router_id | default("1.1.1.1") }}
{% for net in routing.ospf.networks %}
  network {{ net }} area {{ routing.ospf.area }}
{% endfor %}
{% if routing.bgp is defined %}
!
router bgp {{ organization.as_number }}
{% for n in routing.bgp.neighbors %}
  neighbor {{ n.neighbor_ip }} remote-as {{ n.as }}
{% endfor %}
{% endif %}
